@model ProfileListViewModel
@{
    ViewData["Title"] = Model.PageTitle;
}

<div class="row mb-3">
    <div class="col">
        <h2 class="mb-1">@Model.PageTitle</h2>
        <p class="text-muted">@Model.Description</p>
    </div>
</div>

@if (ViewBag.ErrorMessage != null)
{
    <div class="alert alert-danger">@ViewBag.ErrorMessage</div>
}

@if (Model.TotalCount == 0)
{
    <div class="alert alert-info">
        <strong>All good!</strong> Everyone you follow also follows you back.
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <span class="text-muted small">
            Showing @((Model.CurrentPage - 1) * Model.PageSize + 1)&ndash;@(Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalCount))
            of @Model.TotalCount people
        </span>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="thead-light">
                    <tr>
                        <th style="width:56px;"></th>
                        <th>Name</th>
                        <th>Handle</th>
                        <th class="text-right">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var profile in Model.Profiles)
                    {
                        <tr>
                            <td class="align-middle">
                                @if (!string.IsNullOrEmpty(profile.AvatarUrl))
                                {
                                    <img src="@profile.AvatarUrl" alt="" class="avatar rounded-circle" />
                                }
                                else
                                {
                                    <div class="avatar avatar-fallback rounded-circle bg-secondary d-flex align-items-center justify-content-center">
                                        <span class="text-white small font-weight-bold">
                                            @(profile.DisplayLabel.Length > 0 ? profile.DisplayLabel[0].ToString().ToUpper() : "?")
                                        </span>
                                    </div>
                                }
                            </td>
                            <td class="align-middle">
                                <a href="https://bsky.app/profile/@profile.Handle" target="_blank" rel="noopener noreferrer" class="text-body font-weight-medium">
                                    @profile.DisplayLabel
                                </a>
                            </td>
                            <td class="align-middle handle">@@@profile.Handle</td>
                            <td class="align-middle text-right">
                                @if (!string.IsNullOrEmpty(profile.FollowUri))
                                {
                                    <form asp-controller="Following" asp-action="Unfollow" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="followUri" value="@profile.FollowUri" />
                                        <input type="hidden" name="returnPage" value="@Model.CurrentPage" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger"
                                                onclick="return confirm('Unfollow @profile.DisplayLabel? This cannot be undone here.');">
                                            Unfollow
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-muted small">No follow URI</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link"
                       asp-controller="Following" asp-action="NotFollowingBack"
                       asp-route-page="@(Model.CurrentPage - 1)">
                        &laquo; Previous
                    </a>
                </li>

                @for (int i = Math.Max(1, Model.CurrentPage - 2); i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link"
                           asp-controller="Following" asp-action="NotFollowingBack"
                           asp-route-page="@i">@i</a>
                    </li>
                }

                <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                    <a class="page-link"
                       asp-controller="Following" asp-action="NotFollowingBack"
                       asp-route-page="@(Model.CurrentPage + 1)">
                        Next &raquo;
                    </a>
                </li>
            </ul>
        </nav>
        <p class="text-center text-muted small">Page @Model.CurrentPage of @Model.TotalPages</p>
    }
}

<div class="mt-3">
    <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-secondary btn-sm">
        &larr; Back to Dashboard
    </a>
</div>
