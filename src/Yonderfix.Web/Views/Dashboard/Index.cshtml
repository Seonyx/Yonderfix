@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="dash-profile mb-4">
    @if (!string.IsNullOrEmpty(Model.AvatarUrl))
    {
        <img src="@Model.AvatarUrl" alt="Avatar" class="avatar-lg rounded-circle" />
    }
    else
    {
        <div class="avatar-placeholder rounded-circle d-flex align-items-center justify-content-center">
            <span>@(Model.DisplayName.Length > 0 ? Model.DisplayName[0].ToString().ToUpper() : "?")</span>
        </div>
    }
    <div class="dash-profile-info">
        <div class="dash-profile-name">@Model.DisplayName</div>
        <div class="profile-handle">@@@Model.Handle</div>
    </div>
</div>

<div class="dash-stats mb-4">
    <div class="card stat-card stat-followers">
        <div class="card-body">
            <div class="stat-value text-primary">@Model.FollowersCount</div>
            <div class="stat-label">Followers</div>
        </div>
    </div>
    <div class="card stat-card stat-following">
        <div class="card-body">
            <div class="stat-value text-info">@Model.FollowsCount</div>
            <div class="stat-label">Following</div>
        </div>
    </div>
    <div class="card stat-card stat-mutual">
        <div class="card-body">
            <div class="stat-value text-success">@Model.MutualCount</div>
            <div class="stat-label">Mutual</div>
        </div>
    </div>
</div>

<div class="dash-actions">
    <div class="card dash-action-card">
        <div class="card-body">
            <div class="dash-action-count text-primary">@Model.NotFollowingBackCount</div>
            <h5 class="card-title">Followers Not Following Back</h5>
            <p class="card-text text-muted">People who follow you, but you don't follow back.</p>
            <a asp-controller="Followers" asp-action="NotFollowingBack" class="btn btn-outline-primary btn-sm">View &rarr;</a>
        </div>
    </div>
    <div class="card dash-action-card">
        <div class="card-body">
            <div class="dash-action-count text-danger">@Model.NotFollowedBackCount</div>
            <h5 class="card-title">Following Not Following Back</h5>
            <p class="card-text text-muted">People you follow who don't follow you back.</p>
            <a asp-controller="Following" asp-action="NotFollowingBack" class="btn btn-outline-danger btn-sm">View &rarr;</a>
        </div>
    </div>
</div>
