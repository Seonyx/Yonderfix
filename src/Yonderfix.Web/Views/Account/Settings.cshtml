@model SettingsViewModel
@{
    ViewData["Title"] = "Settings";
}

<div class="page-header mb-4">
    <div>
        <h2 class="mb-1">Settings</h2>
        <p class="text-muted mb-0">Configure your Yonderfix preferences</p>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @Model.SuccessMessage
        <button type="button" class="close" data-dismiss="alert" aria-label="Close">
            <span aria-hidden="true">&times;</span>
        </button>
    </div>
}

<div class="settings-wrap">
    <div class="card">
        <div class="card-header">
            <h5>Display Settings</h5>
        </div>
        <div class="card-body">
            <form asp-controller="Account" asp-action="Settings" method="post" id="settingsForm">
                @Html.AntiForgeryToken()

                <div class="settings-field">
                    <label asp-for="PageSize">Items Per Page</label>
                    <div class="settings-field-body">
                        <input asp-for="PageSize"
                               type="number"
                               class="form-control settings-number"
                               min="5"
                               max="100" />
                        <small class="form-text">Number of profiles to show per page (5&ndash;100).</small>
                        <span asp-validation-for="PageSize" class="text-danger small"></span>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary" id="saveBtn">Save Settings</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.getElementById('settingsForm').addEventListener('submit', function() {
        var btn = document.getElementById('saveBtn');
        btn.disabled = true;
        btn.textContent = 'Saving\u2026';
    });
</script>
}
