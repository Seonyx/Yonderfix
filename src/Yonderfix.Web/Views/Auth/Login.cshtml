@model LoginViewModel
@{
    ViewData["Title"] = "Sign In";
    Layout = "_Layout";
}

<div class="login-wrap">
    <div class="login-box">

        <div class="login-header">
            <span class="login-dot"></span>
            <span class="login-brand">Yonderfix</span>
            <p class="login-sub">Bluesky Follower Manager</p>
        </div>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger" role="alert">
                <strong>Sign in failed &mdash;</strong> @Model.ErrorMessage
            </div>
        }

        <form asp-controller="Auth" asp-action="Login" method="post">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label asp-for="Handle">Bluesky Handle</label>
                <input asp-for="Handle"
                       class="form-control"
                       placeholder="you.bsky.social"
                       autocomplete="username"
                       autofocus />
                <small class="form-text">e.g. <em>yourname.bsky.social</em> or your email address</small>
            </div>

            <div class="form-group">
                <label asp-for="AppPassword">App Password</label>
                <input asp-for="AppPassword"
                       type="password"
                       class="form-control"
                       placeholder="xxxx-xxxx-xxxx-xxxx"
                       autocomplete="current-password" />
            </div>

            <button type="submit" class="btn btn-primary btn-block">Sign In</button>
        </form>

        <div class="login-hint">
            <span class="login-hint-title">Using an App Password</span>
            <p>Do not use your main Bluesky password. Generate one at:<br />
            <strong>Settings &rarr; Privacy and Security &rarr; App Passwords</strong></p>
            <p class="mb-0">App passwords are revocable and keep your main password safe.</p>
        </div>

    </div>
</div>
