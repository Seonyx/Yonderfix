@model LoginViewModel
@{
    ViewData["Title"] = "Sign In";
    Layout = "_Layout";
}

<div class="login-wrap">
    <div class="login-box">

        <div class="login-header">
            <span class="login-dot"></span>
            <span class="login-brand">Yonderfix</span>
            <p class="login-sub">Bluesky Follower Manager</p>
        </div>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger" role="alert">
                <strong>Sign in failed &mdash;</strong> @Model.ErrorMessage
            </div>
        }

        <form asp-controller="Auth" asp-action="Login" method="post" id="loginForm">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label asp-for="Handle">Bluesky Handle</label>
                <input asp-for="Handle"
                       class="form-control"
                       placeholder="you.bsky.social"
                       autocomplete="username"
                       autofocus />
                <small class="form-text">e.g. <em>yourname.bsky.social</em> or your email address</small>
            </div>

            <div class="form-group">
                <label asp-for="AppPassword">App Password</label>
                <div class="input-pw-wrap">
                    <input asp-for="AppPassword"
                           type="password"
                           id="appPasswordInput"
                           class="form-control"
                           placeholder="xxxx-xxxx-xxxx-xxxx"
                           autocomplete="current-password" />
                    <button type="button" class="pw-toggle" id="pwToggle" aria-label="Show password" title="Show password">
                        <svg id="pwEyeShow" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                        <svg id="pwEyeHide" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                    </button>
                </div>
            </div>

            <button type="submit" class="btn btn-primary btn-block" id="loginBtn">Sign In</button>
        </form>

        <div class="login-hint">
            <span class="login-hint-title">Using an App Password</span>
            <p>Do not use your main Bluesky password. Generate one at:<br />
            <strong>Settings &rarr; Privacy and Security &rarr; App Passwords</strong></p>
            <p class="mb-0">App passwords are revocable and keep your main password safe.</p>
        </div>

    </div>
</div>

@section Scripts {
<script>
    // Password show/hide toggle
    var pwToggle = document.getElementById('pwToggle');
    var pwInput  = document.getElementById('appPasswordInput');
    var eyeShow  = document.getElementById('pwEyeShow');
    var eyeHide  = document.getElementById('pwEyeHide');
    pwToggle.addEventListener('click', function() {
        var isHidden = pwInput.type === 'password';
        pwInput.type = isHidden ? 'text' : 'password';
        eyeShow.style.display = isHidden ? 'none' : '';
        eyeHide.style.display = isHidden ? ''     : 'none';
        pwToggle.setAttribute('aria-label', isHidden ? 'Hide password' : 'Show password');
    });

    // Button loading state on submit
    document.getElementById('loginForm').addEventListener('submit', function() {
        var btn = document.getElementById('loginBtn');
        btn.disabled = true;
        btn.textContent = 'Signing in\u2026';
        btn.classList.add('loading');
    });
</script>
}
